{
  "data": {
    "train_path": "/path/to/train.tsv",
    "val_path": "/path/to/val.tsv",
    "test_path": "/path/to/test.tsv",
    "delimiter": "\t",
    "has_header": false
  },
  "model": {
    "embedding_dim": 256,
    "compgcn_layers": 2,
    "dropout": 0.2,
    "comp_op": "mul",
    "use_rgcn": false,
    "fusion": "concat",
    "attention_hidden": 256,
    "generator_hidden": 512,
    "discriminator_hidden": 512,
    "noise_dim": 64
  },
  "training": {
    "seed": 7,
    "batch_size": 1024,
    "num_workers": 0,
    "lr": 0.001,
    "weight_decay": 0.00001,
    "max_epochs_pretrain": 5,
    "max_epochs_warmup": 10,
    "max_epochs_gan": 30,
    "patience_pretrain": 5,
    "patience_warmup": 10,
    "patience_gan": 15,
    "grad_clip": 1.0,
    "gan_k": 3,
    "lambda_adv": 0.1,
    "lambda_adv_max": 0.5,
    "lambda_adv_step": 0.05,
    "neighbor_dropout": 0.4,
    "leave_one_out": true,
    "eval_topk": 1000
  },
  "sampling": {
    "easy_ratio": 0.5,
    "medium_ratio": 0.3,
    "hard_ratio": 0.2,
    "hard_update_interval": 5
  },
  "optional": {
    "use_rl_evidence": false,
    "use_patch_reranker": false
  },
  "semantic": {
    "embeddings_dir": null,
    "entity_type_mapping": null
  }
}
